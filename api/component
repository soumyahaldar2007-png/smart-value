import React, { useState } from 'react';

export default function RegistrationForm() {
  // 1. Create state variables to hold the form inputs
  const [firstName, setFirstName] = useState('');
  const [lastName, setLastName] = useState('');
  const [contactNumber, setContactNumber] = useState('');
  const [qualification, setQualification] = useState('');
  const [pursuing, setPursuing] = useState('');

  // 2. The function that sends data to your /api/registrations backend
  const handleRegisterSubmit = async (e) => {
    e.preventDefault();

    if (!firstName || !lastName || !contactNumber) {
      alert("Please fill out your Name and Contact Number.");
      return;
    }

    const payload = { firstName, lastName, contactNumber, qualification, pursuing };

    try {
      const response = await fetch('/api/registrations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (result.success) {
        alert("🎉 Saved to Neon successfully!");
        // Clear form fields
        setFirstName(''); setLastName(''); setContactNumber(''); setQualification(''); setPursuing('');
      } else {
        alert("Error: " + result.error);
      }
    } catch (err) {
      console.error(err);
      alert("Failed to connect to backend server.");
    }
  };

  // 3. Connect the inputs to the state values using value and onChange
  return (
    <div className="registration-container">
      <h3>Registration Page</h3>
      
      <input 
        type="text" 
        placeholder="e.g. Liam" 
        value={firstName} 
        onChange={(e) => setFirstName(e.target.value)} 
      />
      
      <input 
        type="text" 
        placeholder="e.g. Vance" 
        value={lastName} 
        onChange={(e) => setLastName(e.target.value)} 
      />
      
      <input 
        type="text" 
        placeholder="+1 (555) 0199" 
        value={contactNumber} 
        onChange={(e) => setContactNumber(e.target.value)} 
      />
      
      <input 
        type="text" 
        placeholder="e.g. HS" 
        value={qualification} 
        onChange={(e) => setQualification(e.target.value)} 
      />
      
      <input 
        type="text" 
        placeholder="e.g. Science / Arts" 
        value={pursuing} 
        onChange={(e) => setPursuing(e.target.value)} 
      />

      <button onClick={handleRegisterSubmit}>COMPLETE REGISTRATION</button>
    </div>
  );
}
